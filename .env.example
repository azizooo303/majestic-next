# WooCommerce (Cloudways staging)
NEXT_PUBLIC_WC_URL=https://lightyellow-mallard-240169.hostingersite.com
WC_CONSUMER_KEY=ck_xxxx
WC_CONSUMER_SECRET=cs_xxxx

# Site
NEXT_PUBLIC_SITE_URL=https://majestic-next.vercel.app

# Admin Panel
# ADMIN_PASSWORD: the password you log in with at /admin
ADMIN_PASSWORD=change-this-password
# ADMIN_HMAC_SECRET: 64-char hex string used to sign admin tokens.
# Generate with: node -e "require('crypto').randomBytes(32).toString('hex')"
# Set this in Vercel dashboard → Settings → Environment Variables (all environments)
ADMIN_HMAC_SECRET=replace-with-64-char-hex-string

# Monitoring
# Get from sentry.io → Project → Settings → Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=https://xxxx@oxxxx.ingest.sentry.io/xxxx

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxx
SUPABASE_SERVICE_ROLE_KEY=eyJxxxx

# Odoo Sync (Wave 2)
# Live Odoo instance Next.js reads via XML-RPC for sync
ODOO_URL=https://majestic-furniture4.odoo.com
ODOO_DB=majestic-furniture4
ODOO_UID=2
# Generate in Odoo: My Profile → Account Security → New API Key
ODOO_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# HMAC secret for Odoo → Next.js webhook signature verification
# Generate: node -e "require('crypto').randomBytes(32).toString('hex')"
# Set same value in Odoo base.automation Python action
ODOO_SYNC_HMAC_SECRET=replace-with-64-char-hex-string

# Vercel Cron secret for /api/sync/nightly-reconcile
# Set in Vercel dashboard → automatically passed as x-vercel-cron-secret header
CRON_SECRET=replace-with-random-string

# Internal sync token — allows odoo-webhook → translation-sync internal calls without HMAC
INTERNAL_SYNC_TOKEN=replace-with-random-string
